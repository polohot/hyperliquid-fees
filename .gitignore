# Secrets — NEVER commit (.mcp.json = Tavily key; .env = Nansen key + others)
.mcp.json
.env
.env.*
!.env.example

# Node
node_modules/

# Backend derived data (regenerable via backfill — do NOT commit)
backend/data/

# Generated screenshots (regenerable via tools/screenshot.js)
tools/*.png

# Sortino scan artifacts (regenerable; *.log already covered above)
tools/sortino-results.json

# OS / editor cruft
.DS_Store
*.log
.vscode/
.idea/

# Claude Code local config (not part of the site)
.claude/

# Windows mark-of-the-web artifacts (WSL)
*:Zone.Identifier
