# Hyperliquid referral project — environment variables.
# Copy this file to .env and fill in values. .env is gitignored — NEVER commit real secrets.

# === Required: referral link (landing page + gating) ===
HYPE_REFERRAL_LINK=https://app.hyperliquid.xyz/join/YOURCODE

# === Hydromancer Reservoir backfill (AWS S3, requester-pays) ===
# IAM user (e.g. hl-backend) with policy AmazonS3ReadOnlyAccess.
# Bucket region is ap-northeast-1 (Tokyo). Egress bills your AWS account (~$0.09/GB).
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AWS_REGION=ap-northeast-1

# === Optional: research / search ===
TAVILY_API_KEY=tvly-xxxxxxxxxxxx                 # Tavily MCP web search (research agents)
NANSEN_AI_API_KEY=xxxxxxxx                       # Nansen (backup data source — not actively used; free endpoint is better)
